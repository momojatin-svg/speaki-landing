<script>
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => { nav.classList.toggle('scrolled', window.scrollY > 40); });

const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });

document.querySelectorAll('.pain-card,.how-step,.tcard,.just-item,.pillar,.product-block').forEach(el => observer.observe(el));

const mObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.querySelectorAll('.manifesto-line').forEach(line => {
        const delay = parseInt(line.dataset.delay || 0);
        setTimeout(() => line.classList.add('visible'), delay);
      });
      mObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.15 });
const mi = document.querySelector('.manifesto-inner');
if (mi) mObserver.observe(mi);

const bars = document.querySelectorAll('.wave-bar');
function animateWave() {
  bars.forEach((bar, i) => {
    const h = 8 + Math.random() * 22;
    bar.style.transition = 'height 0.3s ease';
    bar.style.height = h + 'px';
  });
}
setInterval(animateWave, 400);
</script>
