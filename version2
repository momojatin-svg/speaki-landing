<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Speaki — Just Speak.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
<style>
:root {
  --forest: #27500A;
  --forest-mid: #3B6D11;
  --green: #639922;
  --green-light: #EAF3DE;
  --green-med: #C0DD97;
  --ember: #D85A30;
  --ember-light: #FAECE7;
  --ember-mid: #993C1D;
  --purple: #534AB7;
  --purple-light: #EEEDFE;
  --teal: #0F6E56;
  --teal-light: #E1F5EE;
  --amber: #854F0B;
  --amber-light: #FAEEDA;
  --charcoal: #2C2C2A;
  --mid: #5F5E5A;
  --light: #F1EFE8;
  --border: #D3D1C7;
  --white: #FDFCF9;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--charcoal);overflow-x:hidden;}

body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:999;opacity:0.4;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 48px;background:rgba(253,252,249,0.88);backdrop-filter:blur(14px);border-bottom:0.5px solid transparent;transition:border-color 0.3s;}
nav.scrolled{border-color:var(--border);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.nav-mark{width:32px;height:32px;background:var(--forest);border-radius:8px;display:flex;align-items:center;justify-content:center;}
.nav-mark svg{width:18px;height:18px;}
.nav-name{font-family:'DM Serif Display',serif;font-size:20px;color:var(--charcoal);letter-spacing:-0.3px;}
.nav-sub{font-size:10px;color:var(--mid);letter-spacing:0.04em;}
.nav-links{display:flex;align-items:center;gap:28px;list-style:none;}
.nav-links a{font-size:13px;color:var(--mid);text-decoration:none;transition:color 0.2s;}
.nav-links a:hover{color:var(--charcoal);}
.nav-cta{background:var(--forest) !important;color:#EAF3DE !important;padding:9px 22px;border-radius:100px;font-weight:500 !important;transition:background 0.2s !important;}
.nav-cta:hover{background:var(--forest-mid) !important;}

/* HERO */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 48px 80px;position:relative;overflow:hidden;background:var(--forest);}
.hero-ring{position:absolute;border-radius:50%;border:0.5px solid rgba(192,221,151,0.12);pointer-events:none;}
.hero-r1{width:600px;height:600px;top:-100px;right:-100px;}
.hero-r2{width:950px;height:950px;top:-280px;right:-280px;}
.hero-r3{width:1300px;height:1300px;top:-450px;right:-450px;}
.hero-eyebrow{position:relative;z-index:2;font-size:11px;font-weight:500;letter-spacing:1.6px;color:var(--green);text-transform:uppercase;margin-bottom:24px;opacity:0;transform:translateY(16px);animation:fadeUp 0.7s ease forwards 0.3s;}
.hero-headline{position:relative;z-index:2;font-family:'DM Serif Display',serif;font-size:clamp(64px,9vw,130px);color:var(--green-light);line-height:0.9;letter-spacing:-2px;margin-bottom:40px;opacity:0;transform:translateY(24px);animation:fadeUp 0.8s ease forwards 0.5s;}
.hero-headline em{font-style:italic;color:var(--green-med);}
.hero-bottom{position:relative;z-index:2;display:flex;align-items:flex-end;justify-content:space-between;gap:40px;opacity:0;transform:translateY(16px);animation:fadeUp 0.7s ease forwards 0.9s;}
.hero-sub{font-size:16px;color:var(--green-med);line-height:1.75;max-width:480px;font-weight:300;}
.hero-sub strong{color:var(--green-light);font-weight:500;}
.hero-actions{display:flex;align-items:center;gap:16px;flex-shrink:0;}
.btn-primary{background:var(--green-light);color:var(--forest);padding:16px 36px;border-radius:100px;font-size:15px;font-weight:500;text-decoration:none;display:inline-block;transition:background 0.2s,transform 0.15s;border:none;cursor:pointer;white-space:nowrap;}
.btn-primary:hover{background:#fff;transform:translateY(-1px);}
.btn-ghost{color:rgba(192,221,151,0.65);font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:color 0.2s;white-space:nowrap;}
.btn-ghost:hover{color:var(--green-med);}
.btn-ghost .arr{transition:transform 0.2s;}
.btn-ghost:hover .arr{transform:translateX(3px);}
.hero-scroll{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:2;display:flex;flex-direction:column;align-items:center;gap:5px;opacity:0;animation:fadeIn 1s ease forwards 1.5s;}
.hero-scroll-line{width:1px;height:36px;background:rgba(192,221,151,0.25);animation:scrollPulse 2.2s ease-in-out infinite;}
.hero-scroll span{font-size:9px;letter-spacing:1.8px;color:rgba(192,221,151,0.35);text-transform:uppercase;}

/* NOT JUST AI — PRODUCT PILLARS */
.pillars-section{background:var(--charcoal);padding:100px 48px;}
.pillars-top{display:flex;align-items:flex-start;justify-content:space-between;gap:40px;margin-bottom:64px;}
.pillars-headline{font-family:'DM Serif Display',serif;font-size:clamp(36px,5vw,60px);color:var(--green-light);line-height:1.05;letter-spacing:-1px;max-width:520px;}
.pillars-headline em{font-style:italic;color:var(--green-med);}
.pillars-intro{max-width:320px;font-size:14px;color:rgba(192,221,151,0.6);line-height:1.75;font-weight:300;padding-top:8px;}
.pillars-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:2px;}
.pillar{padding:32px 28px;position:relative;overflow:hidden;opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;}
.pillar.visible{opacity:1;transform:translateY(0);}
.pillar-inner{position:relative;z-index:1;}
.pillar-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;flex-shrink:0;}
.pillar-icon svg{width:22px;height:22px;}
.pillar-number{font-family:'DM Serif Display',serif;font-size:11px;color:rgba(255,255,255,0.2);letter-spacing:1px;margin-bottom:8px;}
.pillar-title{font-size:16px;font-weight:500;line-height:1.25;margin-bottom:12px;}
.pillar-body{font-size:13px;line-height:1.65;font-weight:300;}
.pillar-tag{display:inline-block;font-size:10px;font-weight:500;padding:3px 10px;border-radius:20px;margin-top:14px;letter-spacing:0.3px;}

.pillar-1{background:rgba(99,153,34,0.12);}
.pillar-1 .pillar-icon{background:rgba(99,153,34,0.2);}
.pillar-1 .pillar-title{color:#C0DD97;}
.pillar-1 .pillar-body{color:rgba(192,221,151,0.55);}
.pillar-1 .pillar-tag{background:rgba(99,153,34,0.2);color:#97C459;}

.pillar-2{background:rgba(83,74,183,0.12);}
.pillar-2 .pillar-icon{background:rgba(83,74,183,0.2);}
.pillar-2 .pillar-title{color:#AFA9EC;}
.pillar-2 .pillar-body{color:rgba(175,169,236,0.55);}
.pillar-2 .pillar-tag{background:rgba(83,74,183,0.2);color:#AFA9EC;}

.pillar-3{background:rgba(15,110,86,0.12);}
.pillar-3 .pillar-icon{background:rgba(15,110,86,0.2);}
.pillar-3 .pillar-title{color:#9FE1CB;}
.pillar-3 .pillar-body{color:rgba(159,225,203,0.55);}
.pillar-3 .pillar-tag{background:rgba(15,110,86,0.2);color:#5DCAA5;}

.pillar-4{background:rgba(215,94,48,0.1);}
.pillar-4 .pillar-icon{background:rgba(215,94,48,0.2);}
.pillar-4 .pillar-title{color:#F0997B;}
.pillar-4 .pillar-body{color:rgba(240,153,123,0.55);}
.pillar-4 .pillar-tag{background:rgba(215,94,48,0.2);color:#F0997B;}

/* TICKER */
.ticker-wrap{background:var(--forest-mid);padding:14px 0;overflow:hidden;white-space:nowrap;}
.ticker-inner{display:inline-flex;animation:ticker 22s linear infinite;}
.ticker-item{font-family:'DM Serif Display',serif;font-size:15px;font-style:italic;color:var(--green-med);padding:0 36px;}
.ticker-dot{color:var(--green);padding:0 4px;}

/* STATS */
.stats-strip{background:var(--green-light);padding:40px 48px;display:flex;align-items:center;gap:0;overflow:hidden;}
.stat-item{flex:1;display:flex;flex-direction:column;align-items:center;padding:0 32px;}
.stat-num{font-family:'DM Serif Display',serif;font-size:40px;color:var(--forest);line-height:1;}
.stat-label{font-size:12px;color:var(--forest-mid);text-align:center;margin-top:4px;line-height:1.4;}
.stat-divider{width:1px;height:56px;background:var(--green-med);flex-shrink:0;}

/* PAIN */
.pain-section{background:var(--white);padding:100px 48px;}
.pain-headline{font-family:'DM Serif Display',serif;font-size:clamp(36px,5vw,64px);color:var(--charcoal);line-height:1.05;letter-spacing:-1px;max-width:680px;margin-bottom:64px;}
.pain-headline em{font-style:italic;color:var(--mid);}
.pain-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;}
.pain-card{background:var(--light);padding:32px;transition:background 0.3s;opacity:0;transform:translateY(20px);}
.pain-card.visible{opacity:1;transform:translateY(0);transition:opacity 0.5s ease,transform 0.5s ease,background 0.3s;}
.pain-card:hover{background:var(--green-light);}
.pain-card:hover .pain-num{color:var(--forest);}
.pain-card:hover .pain-body{color:var(--forest-mid);}
.pain-num{font-family:'DM Serif Display',serif;font-size:44px;color:var(--border);line-height:1;margin-bottom:14px;transition:color 0.3s;}
.pain-title{font-size:15px;font-weight:500;color:var(--charcoal);margin-bottom:8px;line-height:1.3;}
.pain-body{font-size:13px;color:var(--mid);line-height:1.65;transition:color 0.3s;}
.pain-pill{display:inline-block;font-size:10px;font-weight:500;padding:2px 9px;border-radius:20px;margin-top:12px;}

/* PRODUCT DEEP DIVE */
.product-section{background:var(--white);padding:100px 48px;}
.product-label{font-size:10px;font-weight:500;letter-spacing:1.8px;color:var(--green);text-transform:uppercase;margin-bottom:20px;}
.product-headline{font-family:'DM Serif Display',serif;font-size:clamp(32px,4.5vw,56px);color:var(--charcoal);letter-spacing:-0.8px;margin-bottom:72px;line-height:1.08;max-width:600px;}
.product-headline em{font-style:italic;color:var(--forest);}

.product-block{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-bottom:80px;opacity:0;transform:translateY(28px);transition:opacity 0.7s ease,transform 0.7s ease;}
.product-block.visible{opacity:1;transform:translateY(0);}
.product-block:last-child{margin-bottom:0;}
.product-block.reverse{direction:rtl;}
.product-block.reverse > *{direction:ltr;}

.product-content{}
.product-pillar-badge{display:inline-flex;align-items:center;gap:8px;font-size:11px;font-weight:500;padding:5px 14px;border-radius:100px;margin-bottom:20px;}
.product-block-title{font-family:'DM Serif Display',serif;font-size:clamp(26px,3vw,38px);color:var(--charcoal);line-height:1.1;letter-spacing:-0.5px;margin-bottom:16px;}
.product-block-body{font-size:14px;color:var(--mid);line-height:1.8;margin-bottom:20px;font-weight:300;}
.product-features{list-style:none;display:flex;flex-direction:column;gap:8px;}
.product-features li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--charcoal);line-height:1.5;}
.product-features li::before{content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:6px;}

.product-visual{border-radius:20px;overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;position:relative;}

/* Live sessions visual */
.live-visual{background:var(--charcoal);}
.live-inner{padding:28px;width:100%;}
.live-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.live-dot{display:flex;align-items:center;gap:6px;font-size:12px;color:#97C459;font-weight:500;}
.live-dot::before{content:'';width:8px;height:8px;border-radius:50%;background:#97C459;animation:pulse 1.5s ease-in-out infinite;}
.live-avatars{display:flex;gap:-8px;}
.live-avatar{width:32px;height:32px;border-radius:50%;border:2px solid var(--charcoal);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;margin-left:-8px;}
.live-avatar:first-child{margin-left:0;}
.live-session-card{background:rgba(255,255,255,0.06);border:0.5px solid rgba(255,255,255,0.1);border-radius:12px;padding:16px;margin-bottom:10px;}
.live-session-title{font-size:13px;font-weight:500;color:#EAF3DE;margin-bottom:4px;}
.live-session-meta{font-size:11px;color:rgba(192,221,151,0.5);}
.live-session-card.active{background:rgba(99,153,34,0.15);border-color:rgba(99,153,34,0.3);}
.live-session-card.active .live-session-title{color:#C0DD97;}
.live-waveform{display:flex;align-items:center;gap:3px;margin-top:16px;height:32px;}
.wave-bar{width:4px;border-radius:2px;background:rgba(99,153,34,0.4);}

/* AI Coach visual */
.ai-visual{background:var(--purple-light);}
.ai-inner{padding:24px;width:100%;}
.ai-chat{display:flex;flex-direction:column;gap:10px;}
.ai-msg{padding:11px 14px;border-radius:12px;font-size:12px;line-height:1.55;max-width:85%;}
.ai-msg.user{background:#EEEDFE;color:#26215C;align-self:flex-end;border-radius:12px 12px 2px 12px;}
.ai-msg.coach{background:var(--purple);color:#EEEDFE;align-self:flex-start;border-radius:12px 12px 12px 2px;}
.ai-msg.feedback{background:rgba(83,74,183,0.12);color:#534AB7;font-size:11px;border:0.5px solid rgba(83,74,183,0.2);border-radius:8px;}
.ai-time{font-size:10px;color:rgba(83,74,183,0.4);text-align:center;margin:4px 0;}

/* Community visual */
.community-visual{background:var(--teal-light);}
.community-inner{padding:24px;width:100%;}
.community-post{background:#fff;border-radius:12px;padding:14px;margin-bottom:10px;border:0.5px solid rgba(15,110,86,0.15);}
.community-post-header{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.community-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;}
.community-name{font-size:12px;font-weight:500;color:var(--charcoal);}
.community-flag{font-size:12px;}
.community-text{font-size:12px;color:var(--mid);line-height:1.5;}
.community-reactions{display:flex;gap:8px;margin-top:8px;}
.reaction{font-size:10px;color:var(--mid);background:var(--light);padding:2px 8px;border-radius:20px;}

/* Gamified visual */
.gamified-visual{background:var(--amber-light);}
.gamified-inner{padding:24px;width:100%;}
.streak-row{display:flex;align-items:center;justify-content:space-between;background:#fff;border-radius:12px;padding:14px 16px;margin-bottom:10px;border:0.5px solid rgba(133,79,11,0.1);}
.streak-label{font-size:12px;color:var(--mid);}
.streak-val{font-family:'DM Serif Display',serif;font-size:20px;color:var(--amber);line-height:1;}
.streak-sub{font-size:10px;color:rgba(133,79,11,0.5);}
.xp-bar-wrap{background:#fff;border-radius:12px;padding:14px 16px;margin-bottom:10px;border:0.5px solid rgba(133,79,11,0.1);}
.xp-label{display:flex;justify-content:space-between;font-size:11px;color:var(--mid);margin-bottom:8px;}
.xp-track{height:8px;background:var(--amber-light);border-radius:4px;overflow:hidden;}
.xp-fill{height:100%;background:var(--amber);border-radius:4px;width:68%;}
.badge-row{display:flex;gap:8px;flex-wrap:wrap;}
.badge{background:#fff;border:0.5px solid rgba(133,79,11,0.15);border-radius:8px;padding:8px 12px;font-size:10px;color:var(--amber);font-weight:500;display:flex;align-items:center;gap:4px;}
.badge-icon{width:16px;height:16px;background:var(--amber-light);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:9px;}

/* MANIFESTO */
.manifesto-section{background:var(--forest);padding:120px 48px;position:relative;overflow:hidden;}
.manifesto-ring{position:absolute;border-radius:50%;border:0.5px solid rgba(192,221,151,0.07);pointer-events:none;}
.mr1{width:500px;height:500px;bottom:-150px;left:-150px;}
.mr2{width:850px;height:850px;bottom:-320px;left:-320px;}
.manifesto-inner{max-width:800px;position:relative;z-index:1;}
.manifesto-line{font-family:'DM Serif Display',serif;font-size:clamp(26px,4vw,48px);color:var(--green-med);line-height:1.15;letter-spacing:-0.5px;margin-bottom:8px;opacity:0;transform:translateX(-20px);}
.manifesto-line.visible{animation:slideIn 0.6s ease forwards;}
.manifesto-line.bold{color:var(--green-light);font-size:clamp(32px,5vw,60px);margin-top:24px;}
.manifesto-line.final{color:#EAF3DE;font-size:clamp(48px,7.5vw,100px);letter-spacing:-2px;margin-top:16px;}

/* HOW IT WORKS */
.how-section{background:var(--light);padding:100px 48px;}
.how-headline{font-family:'DM Serif Display',serif;font-size:clamp(30px,4vw,52px);color:var(--charcoal);letter-spacing:-0.8px;margin-bottom:56px;max-width:480px;line-height:1.1;}
.how-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;}
.how-step{opacity:0;transform:translateY(24px);transition:opacity 0.6s ease,transform 0.6s ease;}
.how-step.visible{opacity:1;transform:translateY(0);}
.how-num{width:40px;height:40px;border-radius:50%;background:var(--green-light);display:flex;align-items:center;justify-content:center;font-family:'DM Serif Display',serif;font-size:18px;color:var(--forest);margin-bottom:20px;}
.how-title{font-size:18px;font-weight:500;color:var(--charcoal);margin-bottom:10px;line-height:1.2;}
.how-body{font-size:14px;color:var(--mid);line-height:1.7;}
.how-just{font-family:'DM Serif Display',serif;font-size:14px;font-style:italic;color:var(--green);margin-top:12px;}

/* TESTIMONIALS */
.testimonials-section{background:var(--white);padding:100px 48px;}
.testimonials-headline{font-family:'DM Serif Display',serif;font-size:clamp(28px,3.5vw,44px);color:var(--charcoal);letter-spacing:-0.6px;margin-bottom:48px;line-height:1.1;}
.testimonials-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;}
.tcard{background:var(--white);border:0.5px solid var(--border);border-radius:16px;padding:28px;opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;}
.tcard.visible{opacity:1;transform:translateY(0);}
.tquote{font-family:'Instrument Serif',serif;font-style:italic;font-size:16px;color:var(--charcoal);line-height:1.65;margin-bottom:20px;}
.taccent{color:var(--forest);font-style:normal;}
.tauthor{display:flex;align-items:center;gap:12px;}
.tavatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;}
.tname{font-size:13px;font-weight:500;color:var(--charcoal);}
.trole{font-size:12px;color:var(--mid);}

/* JUST VARIATIONS */
.just-section{background:var(--green-light);padding:80px 48px;}
.just-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;}
.just-item{background:var(--white);padding:28px 24px;opacity:0;transform:scale(0.97);transition:opacity 0.4s ease,transform 0.4s ease,background 0.25s;}
.just-item.visible{opacity:1;transform:scale(1);}
.just-item:hover{background:var(--forest);}
.just-item:hover .just-phrase{color:var(--green-light);}
.just-item:hover .just-desc{color:var(--green-med);}
.just-phrase{font-family:'DM Serif Display',serif;font-size:22px;color:var(--charcoal);margin-bottom:8px;transition:color 0.25s;}
.just-desc{font-size:12px;color:var(--mid);line-height:1.55;transition:color 0.25s;}

/* CTA */
.cta-section{background:var(--white);padding:120px 48px;text-align:center;position:relative;overflow:hidden;}
.cta-bg-text{position:absolute;font-family:'DM Serif Display',serif;font-size:20vw;color:var(--light);white-space:nowrap;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;letter-spacing:-4px;line-height:1;z-index:0;}
.cta-inner{position:relative;z-index:1;}
.cta-label{font-size:11px;font-weight:500;letter-spacing:1.8px;color:var(--green);text-transform:uppercase;margin-bottom:20px;}
.cta-headline{font-family:'DM Serif Display',serif;font-size:clamp(40px,6vw,84px);color:var(--charcoal);line-height:0.95;letter-spacing:-1.5px;margin-bottom:16px;}
.cta-headline em{font-style:italic;color:var(--forest);}
